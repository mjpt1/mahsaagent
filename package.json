{
  "name": "mahsaagent",
  "version": "0.3.0",
  "description": "Persian developer toolkit: RTL for editors, Jalali locale tools, Iranian validation, and UI skills",
  "type": "module",
  "bin": {
    "mahsaagent": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/server.js",
    "./jalali": "./dist/lib/jalali.js",
    "./text": "./dist/lib/text.js"
  },
  "files": [
    "dist",
    "rtl",
    "skills",
    "extension",
    "config"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js serve",
    "demo": "node dist/index.js demo",
    "doctor": "node dist/index.js doctor",
    "tools": "node dist/index.js tools",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/smoke.test.ts src/lib/wordsToNumber.test.ts src/lib/nationalId.test.ts"
  },
  "keywords": [
    "persian",
    "farsi",
    "rtl",
    "jalali",
    "shamsi",
    "locale",
    "cursor",
    "vscode",
    "sheba",
    "national-id"
  ],
  "author": "Mahsaagent",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@persian-tools/persian-tools": "^3.6.0",
    "jalaali-js": "^1.2.8",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

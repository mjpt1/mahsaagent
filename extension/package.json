{
  "name": "mahsaagent-rtl",
  "displayName": "Mahsaagent",
  "description": "Persian RTL, Jalali insert, polish selection, and Iranian field validation helpers for the editor.",
  "version": "0.6.2",
  "publisher": "mahsaagent",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Language Packs"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mahsaagent.showPanel",
        "title": "Mahsaagent: Open panel"
      },
      {
        "command": "mahsaagent.copyRtlSnippet",
        "title": "Mahsaagent: Copy RTL snippet"
      },
      {
        "command": "mahsaagent.copyRtlRemove",
        "title": "Mahsaagent: Copy RTL remove snippet"
      },
      {
        "command": "mahsaagent.insertJalaliToday",
        "title": "Mahsaagent: Insert Jalali today"
      },
      {
        "command": "mahsaagent.polishSelection",
        "title": "Mahsaagent: Polish Persian selection"
      },
      {
        "command": "mahsaagent.validateSelection",
        "title": "Mahsaagent: Validate selection"
      },
      {
        "command": "mahsaagent.showRtlHelp",
        "title": "Mahsaagent: RTL setup help"
      }
    ]
  },
  "keywords": ["persian", "farsi", "arabic", "rtl", "jalali", "cursor"],
  "license": "MIT"
}
